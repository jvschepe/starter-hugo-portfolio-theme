@article{gielen_squares_2014,
 abstract = {Deterioration of hand function can be important in multiple sclerosis (MS). The standard way of assessing hand function in MS is the 9-hole peg test (9HPT), one  of the three components of the MS functional composite measure. In this study we  examine the squares test (ST), a test of hand function that is used extensively  in handedness research. We evaluated reproducibility of the ST in 49 healthy  controls, and both discriminatory power and concurrent validity of the ST in 38  MS patients and 18 age and gender matched controls. The ST proved to be a  reliable and easy to administrate paper-and-pencil test of hand function. The ST  showed a high and highly significant correlation with the standard 9HPT over a  broad range of Expanded Disability Status Scale (EDSS) scores, and had high  discriminatory power, also comparable to the 9HPT. Therefore, the ST is a  candidate test for use in composite measures of MS related functional deficits  for clinical practice and in clinical trials.},
 address = {Netherlands},
 author = {Gielen, Jeroen and Laton, Jorne and Van Schependom, J. and De Deyn, P. P. and Nagels, Guy},
 copyright = {Copyright © 2014 Elsevier B.V. All rights reserved.},
 doi = {10.1016/j.clineuro.2014.05.008},
 issn = {1872-6968 0303-8467},
 journal = {Clinical neurology and neurosurgery},
 keywords = {Adult, Aged, Aged, 80 and over, Disability Evaluation, Female, Functional composite, Hand function, Hand/*physiopathology, Humans, Male, Middle Aged, Multiple sclerosis, Multiple Sclerosis/complications/*physiopathology, Nine-hole peg test, Reproducibility of Results, Squares test},
 language = {eng},
 month = {August},
 pages = {55--60},
 title = {The squares test as a measure of hand function in multiple sclerosis.},
 volume = {123},
 year = {2014}
}

