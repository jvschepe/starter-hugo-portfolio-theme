@article{goossens_eeg_2017,
 abstract = {We investigated the power of EEG as biomarker in differential diagnosis of Alzheimer's disease (AD) and frontotemporal lobar degeneration (FTLD). EEG was  recorded from 106 patients with AD or FTLD, of which 37 had a definite diagnosis,  and 40 controls. Dominant frequency peaks were extracted for all 19 channels, for  each subject. The average frequency of the largest dominant frequency peaks  (maxpeak) was significantly lower in AD than FTLD patients and controls. Based on  ROC analysis, classification could be made with diagnostic accuracy of 78.9%. Our  findings show that quantitative analysis of EEG maxpeak frequency is an easy and  useful measure for differential dementia diagnosis.},
 address = {United States},
 author = {Goossens, Joery and Laton, Jorne and Van Schependom, Jeroen and Gielen, Jeroen and Struyfs, Hanne and Van Mossevelde, Sara and Van den Bossche, Tobi and Goeman, Johan and De Deyn, Peter Paul and Sieben, Anne and Martin, Jean-Jacques and Van Broeckhoven, Christine and van der Zee, Julie and Engelborghs, Sebastiaan and Nagels, Guy},
 doi = {10.3233/JAD-160188},
 issn = {1875-8908 1387-2877},
 journal = {Journal of Alzheimer's disease : JAD},
 keywords = {*Electroencephalography, Aged, Alzheimer Disease/*diagnosis/*physiopathology, Alzheimer’s disease, biomarkers, Brain/*physiopathology, Cohort Studies, Diagnosis, Differential, differential diagnosis, electroencephalography, Female, Frontotemporal Lobar Degeneration/*diagnosis/*physiopathology, frontotemporal lobardegeneration, Humans, Male, ROC Curve},
 language = {eng},
 number = {1},
 pages = {53--58},
 title = {EEG Dominant Frequency Peak Differentiates Between Alzheimer's Disease and Frontotemporal Lobar Degeneration.},
 volume = {55},
 year = {2017}
}

