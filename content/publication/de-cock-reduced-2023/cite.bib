@article{de_cock_reduced_2023,
 abstract = {OBJECTIVE: Cognitive impairment is common in multiple sclerosis (MS), significantly impacts daily functioning, is time-consuming to assess, and is  prone to practice effects. We examined whether the alpha band power measured with  magnetoencephalography (MEG) is associated with the different cognitive domains  affected by MS. METHODS: Sixty-eight MS patients and 47 healthy controls  underwent MEG, T1- and FLAIR-weighted magnetic resonance imaging (MRI), and  neuropsychological testing. Alpha power in the occipital cortex was quantified in  the alpha1 (8-10 Hz) and alpha2 (10-12 Hz) bands. Next, we performed best subset  regression to assess the added value of neurophysiological measures to commonly  available MRI measures. RESULTS: Alpha2 power significantly correlated with  information processing speed (p \textless 0.001) and was always retained in all  multilinear models, whereas thalamic volume was retained in 80% of all models.  Alpha1 power was correlated with visual memory (p \textless 0.001) but only retained in  38% of all models. CONCLUSIONS: Alpha2 (10-12 Hz) power in rest is associated  with IPS, independent of standard MRI parameters. This study stresses that a  multimodal assessment, including structural and functional biomarkers, is likely  required to characterize cognitive impairment in MS. Resting-state  neurophysiology is thus a promising tool to understand and follow up changes in  IPS.},
 address = {England},
 author = {De Cock, Alexander and Van Ranst, Alexander and Costers, Lars and Keytsman, Eva and D'Hooghe, Marie B. and D'Haeseleer, Miguel and Nagels, Guy and Van Schependom, Jeroen},
 copyright = {© 2023 European Academy of Neurology.},
 doi = {10.1111/ene.15927},
 issn = {1468-1331 1351-5101},
 journal = {European journal of neurology},
 keywords = {*Cognition Disorders/psychology, *Multiple Sclerosis/complications/diagnostic imaging/pathology, alpha power, Brain/pathology, cognition, Cognition/physiology, Humans, Magnetic Resonance Imaging, magnetoencephalography, Magnetoencephalography/methods, multiple sclerosis, neurophysiology, Neuropsychological Tests, Processing Speed},
 language = {eng},
 month = {September},
 number = {9},
 pages = {2793--2800},
 title = {Reduced alpha2 power is associated with slowed information processing speed in multiple sclerosis.},
 volume = {30},
 year = {2023}
}

